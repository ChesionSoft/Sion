{
  "name": "sion-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc -b && vite build",
    "lint": "tsc -b --pretty false",
    "test": "npm run lint",
    "test:ui": "node --test --experimental-strip-types tests/*.test.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:no-browser-runtime": "node scripts/verify-no-browser-runtime.mjs",
    "test:no-legacy-migration-runtime": "node scripts/verify-no-legacy-migration-runtime.mjs",
    "test:storage-contract": "node scripts/verify-storage-contract.mjs",
    "build:desktop": "tauri build --no-bundle",
    "bundle": "npm run bundle:mac",
    "bundle:mac": "tauri build --bundles app,dmg",
    "bundle:mac-universal": "tauri build --target universal-apple-darwin --bundles app,dmg",
    "bundle:windows": "tauri build --bundles nsis,msi",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/cli": "2.11.4",
    "@vitejs/plugin-react": "6.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "5.9.3",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}

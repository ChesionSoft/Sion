{
  "name": "sion-desktop-spike",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc -b && vite build",
    "lint": "tsc -b --pretty false",
    "test": "npm run lint",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:keyring": "cargo test --manifest-path src-tauri/Cargo.toml keyring_check::tests::round_trips_a_real_system_credential -- --ignored --exact",
    "test:provider-migration": "cargo test --manifest-path src-tauri/Cargo.toml provider_migration::tests::writes_provider_keys_to_the_real_system_credential_store -- --ignored --exact",
    "build:desktop": "tauri build --no-bundle",
    "bundle": "tauri build --bundles app",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/cli": "2.11.4",
    "@vitejs/plugin-react": "6.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "8.1.4",
    "typescript": "5.9.3"
  },
  "devDependencies": {}
}

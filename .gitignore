# Local dependencies and build output
/node_modules/
/dist/
/target/
/src-tauri/target/
/src-tauri/gen/
*.tsbuildinfo

# Local project data and planning materials
/projects/*
!/projects/.gitkeep
/settings/*
/docs/

# Editor, system, and local configuration files
.DS_Store
*.pem
.env*
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.vercel

# Keep repository metadata while ignoring local dotfiles.
.*
!.gitignore
!.github/
!.github/**

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
